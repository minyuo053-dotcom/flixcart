# FlexiCart Environment Variables
# Copy this to .env and fill in your values

# Database
DATABASE_URL=mysql://user:password@host:3306/flexicart

# Session signing secret -- REQUIRED. Set this to any long random string.
# This is what makes login sessions work; without it, no one can log in.
APP_SECRET=replace-with-a-long-random-string

# SMTP (for sending OTP emails). If left blank, OTP codes are logged to the
# server console and returned in the API response instead, so you can still
# test signup/login locally without email configured.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Optional: only needed if you want to keep the "Sign in with Kimi" OAuth
# button. The site's real login (email + OTP) does not require these.
VITE_KIMI_AUTH_URL=
VITE_APP_ID=
KIMI_AUTH_URL=
KIMI_OPEN_URL=

# Percentage added ON TOP of a seller's listed price to get what the
# customer pays. The seller always keeps their full listed price -- this
# fee is never deducted from them. Admin's own house listings have no fee.
PLATFORM_FEE_PERCENT=5

# Used ONLY by `npm run seed:admin` to create/update the admin account.
# Not read by the running app -- safe to remove after you've run the script.
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=choose-a-strong-password

# Required for sellers to upload their product verification videos in the
# admin approval chat. Create an S3 bucket and an IAM user with PutObject
# permission on it, then fill these in. Without them, video upload will
# fail with a clear error, but text chat still works.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
